#!/usr/bin/env bash
# rollout-status.sh — Check deployment pipeline: commit → container registry → ArgoCD → K8s pod
# Generated by AI for project: {{PROJECT_NAME}}
# Usage: ./rollout-status.sh <service> [commit-sha]
#
# Examples:
#   ./rollout-status.sh my-service
#   ./rollout-status.sh my-service eb28443

set -euo pipefail

# ============================================================
# PROJECT CONFIG — filled by AI when generating this script
# ============================================================
KUBECTL_CONTEXT="{{KUBECTL_CONTEXT}}"       # e.g. your-cluster-prod
AWS_PROFILE="{{AWS_PROFILE}}"               # e.g. prod
AWS_REGION="{{AWS_REGION}}"                 # e.g. <AWS_REGION>
ARGOCD_NAMESPACE="{{ARGOCD_NAMESPACE}}"     # e.g. argocd
IMAGE_PREFIX="{{IMAGE_PREFIX}}"             # e.g. master (branch prefix for image tags)

# Service → Namespace mapping
# Add/remove entries as needed for this project
get_namespace() {
  case "$1" in
{{NAMESPACE_MAPPING}}
    *) echo "{{DEFAULT_NAMESPACE}}" ;;
  esac
}

# ArgoCD app name (usually same as service, override if different)
get_argocd_app() {
  case "$1" in
{{ARGOCD_APP_MAPPING}}
    *) echo "$1" ;;
  esac
}
# ============================================================

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

ok()   { echo -e "${GREEN}✅ $*${NC}"; }
fail() { echo -e "${RED}❌ $*${NC}"; }
warn() { echo -e "${YELLOW}⚠️  $*${NC}"; }
info() { echo -e "${BLUE}ℹ️  $*${NC}"; }

# Args
SERVICE="${1:?Usage: $0 <service> [commit-sha]}"
COMMIT_SHA="${2:-}"
NAMESPACE=$(get_namespace "$SERVICE")
ARGOCD_APP=$(get_argocd_app "$SERVICE")

echo ""
echo "=========================================="
echo " Rollout Status: $SERVICE"
echo "=========================================="

# ----------------------------------------------------------
# Step 1: Commit SHA
# ----------------------------------------------------------
echo ""
echo "--- Step 1: Commit SHA ---"
if [[ -z "$COMMIT_SHA" ]]; then
  COMMIT_SHA=$(git log --oneline -1 2>/dev/null | cut -d' ' -f1 || echo "")
fi

if [[ -z "$COMMIT_SHA" ]]; then
  warn "Could not determine commit SHA (not in a git repo?)"
  COMMIT_SHA="unknown"
else
  SHORT_SHA="${COMMIT_SHA:0:8}"
  COMMIT_MSG=$(git log --oneline -1 2>/dev/null | cut -d' ' -f2- || echo "")
  ok "Commit: $SHORT_SHA — $COMMIT_MSG"
fi
SHORT_SHA="${COMMIT_SHA:0:8}"

# ----------------------------------------------------------
# Step 2: Container Registry Image
# ----------------------------------------------------------
echo ""
echo "--- Step 2: Container Registry Image ---"
ECR_TAG=""
ECR_PUSHED_AT=""

ECR_RESULT=$(aws ecr describe-images \
  --profile "$AWS_PROFILE" \
  --repository-name "$SERVICE" \
  --region "$AWS_REGION" \
  --output json 2>&1) || true

read -r ECR_TAG ECR_PUSHED_AT < <(echo "$ECR_RESULT" | python3 -c "
import json, sys
sha = sys.argv[1]
data = json.load(sys.stdin)
for img in sorted(data.get('imageDetails', []), key=lambda x: x.get('imagePushedAt',''), reverse=True):
    for tag in img.get('imageTags', []):
        if sha in tag:
            print(tag, img.get('imagePushedAt', ''))
            sys.exit(0)
" "$SHORT_SHA" 2>/dev/null || echo "")

if [[ -n "$ECR_TAG" ]]; then
  ok "Image found: $ECR_TAG (pushed: $ECR_PUSHED_AT)"
else
  fail "Image NOT found for ${IMAGE_PREFIX}-${SHORT_SHA}"
  echo ""
  info "Latest 5 images in registry:"
  aws ecr describe-images \
    --profile "$AWS_PROFILE" \
    --repository-name "$SERVICE" \
    --region "$AWS_REGION" \
    --query "sort_by(imageDetails, &imagePushedAt)[-5:].{tag:imageTags[0],pushedAt:imagePushedAt}" \
    --output table 2>&1 || true
  echo ""
  warn "CI pipeline may not have run. Trigger 'build-prod' manually in your CI system."
fi

# ----------------------------------------------------------
# Step 3: ArgoCD
# ----------------------------------------------------------
echo ""
echo "--- Step 3: ArgoCD ---"
ARGO_STATUS=$(kubectl --context "$KUBECTL_CONTEXT" \
  get application "$ARGOCD_APP" -n "$ARGOCD_NAMESPACE" \
  -o jsonpath='{.status.sync.status} {.status.health.status} {.status.operationState.phase}' 2>&1) || ARGO_STATUS="ERROR"

ARGO_LAST_SYNC=$(kubectl --context "$KUBECTL_CONTEXT" \
  get application "$ARGOCD_APP" -n "$ARGOCD_NAMESPACE" \
  -o jsonpath='{.status.operationState.finishedAt}' 2>&1) || ARGO_LAST_SYNC=""

ARGO_IMAGE=$(kubectl --context "$KUBECTL_CONTEXT" \
  get application "$ARGOCD_APP" -n "$ARGOCD_NAMESPACE" -o json 2>/dev/null | python3 -c "
import json, sys
app = json.load(sys.stdin)
helm = app.get('spec', {}).get('source', {}).get('helm', {})
for p in helm.get('parameters', []):
    if 'image' in p.get('name','').lower() or 'tag' in p.get('name','').lower():
        print(p['value'])
" 2>/dev/null | head -1) || ARGO_IMAGE=""

if [[ "$ARGO_STATUS" == *"Synced"*"Healthy"* ]]; then
  ok "ArgoCD: $ARGO_STATUS (last sync: $ARGO_LAST_SYNC)"
else
  fail "ArgoCD: $ARGO_STATUS"
fi

if [[ -n "$ARGO_IMAGE" ]]; then
  if [[ "$ARGO_IMAGE" == *"$SHORT_SHA"* ]]; then
    ok "ArgoCD image param: $ARGO_IMAGE"
  else
    warn "ArgoCD image param is NOT the new SHA: $ARGO_IMAGE"
  fi
fi

# ----------------------------------------------------------
# Step 4: K8s Pod
# ----------------------------------------------------------
echo ""
echo "--- Step 4: K8s Pod ---"
POD_INFO=$(kubectl --context "$KUBECTL_CONTEXT" \
  get pods -n "$NAMESPACE" -l "app.name=$SERVICE" \
  -o jsonpath='{range .items[*]}{.metadata.name}{" | "}{.spec.containers[0].image}{" | "}{.status.phase}{" | "}{.status.startTime}{"\n"}{end}' 2>&1) || POD_INFO=""

if [[ -z "$POD_INFO" ]]; then
  fail "No pods found in namespace '$NAMESPACE' with label app.name=$SERVICE"
else
  while IFS='|' read -r pod_name pod_image pod_phase pod_start; do
    pod_name=$(echo "$pod_name" | xargs)
    pod_image=$(echo "$pod_image" | xargs)
    pod_phase=$(echo "$pod_phase" | xargs)
    pod_start=$(echo "$pod_start" | xargs)

    if [[ "$pod_image" == *"$SHORT_SHA"* ]]; then
      ok "Pod: $pod_name"
      ok "  Image: $pod_image"
    else
      warn "Pod: $pod_name"
      warn "  Image (old?): $pod_image"
    fi
    info "  Phase: $pod_phase | Started: $pod_start"
  done <<< "$POD_INFO"
fi

# ----------------------------------------------------------
# Summary
# ----------------------------------------------------------
echo ""
echo "=========================================="
echo " Summary"
echo "=========================================="
printf "%-15s %s\n" "Commit:"    "$SHORT_SHA"
printf "%-15s %s\n" "Image:"     "${ECR_TAG:-NOT FOUND}"
printf "%-15s %s\n" "ArgoCD:"    "$ARGO_STATUS"
printf "%-15s %s\n" "Namespace:" "$NAMESPACE"
echo ""
